    "# Calculate margin for each constituency\n",
    "def get_margin(group):\n",
    "    s = group.sort_values('TOTAL_VOTES', ascending=False).reset_index(drop=True)\n",
    "    if len(s) >= 2:\n",
    "        return pd.Series({\n",
    "            'AC_NAME':       s.iloc[0]['AC_NAME'],\n",
    "            'WINNER':        s.iloc[0]['CANDIDATE'],\n",
    "            'WINNER_PARTY':  s.iloc[0]['PARTY'],\n",
    "            'WINNER_VOTES':  s.iloc[0]['TOTAL_VOTES'],\n",
    "            'RUNNER_UP':     s.iloc[1]['CANDIDATE'],\n",
    "            'RUNNER_PARTY':  s.iloc[1]['PARTY'],\n",
    "            'RUNNER_VOTES':  s.iloc[1]['TOTAL_VOTES'],\n",
    "            'MARGIN':        s.iloc[0]['TOTAL_VOTES'] - s.iloc[1]['TOTAL_VOTES'],\n",
    "            'TOTAL_ELECTORS':s.iloc[0]['TOTAL_ELECTORS'],\n",
    "            'TOTAL_VOTES_CAST': s['TOTAL_VOTES'].sum(),\n",
    "            'NUM_CANDIDATES':len(s),\n",
    "        })\n",
    "\n",
    "margins = df.groupby('AC_NO').apply(get_margin).reset_index()\n",
    "margins['MARGIN_PCT'] = (margins['MARGIN'] / margins['TOTAL_ELECTORS'] * 100).round(2)\n",
    "margins['TURNOUT_PCT'] = (margins['TOTAL_VOTES_CAST'] / margins['TOTAL_ELECTORS'] * 100).round(2)\n",
    "\n",
    "print(f\"Total constituencies: {len(margins)}\")\n",
    "print(f\"Seats with margin < 5,000:  {len(margins[margins['MARGIN'] < 5000])}\")\n",
    "print(f\"Seats with margin < 10,000: {len(margins[margins['MARGIN'] < 10000])}\")\n",
    "print(f\"\\nSmallest margin: {margins['MARGIN'].min():.0f} votes ({margins.loc[margins['MARGIN'].idxmin(), 'AC_NAME']})\")\n",
    "print(f\"Largest margin:  {margins['MARGIN'].max():.0f} votes ({margins.loc[margins['MARGIN'].idxmax(), 'AC_NAME']})\")\n"
   ]
